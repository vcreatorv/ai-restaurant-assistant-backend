{
  "info": {
    "name": "AI Restaurant Assistant — runbook",
    "description": "End-to-end прогон auth + profile + menu (public + admin) + image upload.\n\nКоллекция:\n- автоматически подставляет X-CSRF-Token из collection variable `csrf`;\n- автоматически обновляет `csrf` после ответов /auth/session, /auth/register, /auth/login;\n- использует cookie jar Postman (session_id сохраняется между запросами);\n- в Tests запросов admin-create операции сохраняют id в коллекционные переменные (categoryId, tagId, dishId).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef0123456789"
  },
  "variable": [
    { "key": "baseUrl",       "value": "http://localhost:8081/api/v1", "type": "string" },
    { "key": "csrf",          "value": "",                              "type": "string" },
    { "key": "email",         "value": "test@example.com",              "type": "string" },
    { "key": "password",      "value": "secret123",                     "type": "string" },
    { "key": "newPassword",   "value": "newsecret456",                  "type": "string" },
    { "key": "adminEmail",    "value": "admin@example.com",             "type": "string" },
    { "key": "adminPassword", "value": "adminpass1",                    "type": "string" },
    { "key": "categoryId",    "value": "",                              "type": "string" },
    { "key": "tagId",         "value": "",                              "type": "string" },
    { "key": "dishId",        "value": "",                              "type": "string" },
    { "key": "chatId",        "value": "",                              "type": "string" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const csrf = pm.collectionVariables.get('csrf');",
          "if (csrf) {",
          "    pm.request.headers.upsert({ key: 'X-CSRF-Token', value: csrf });",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "try {",
          "    const body = pm.response.json();",
          "    if (body && typeof body.csrf === 'string' && body.csrf.length > 0) {",
          "        pm.collectionVariables.set('csrf', body.csrf);",
          "    }",
          "} catch (e) {",
          "    // not JSON (e.g. 204) — ничего не делаем",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Базовый прогон auth + profile (см. POSTMAN.md шаги 1–13).",
      "item": [
        {
          "name": "1. Bootstrap session (GET /auth/session)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/session", "host": ["{{baseUrl}}"], "path": ["auth", "session"] }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "const body = pm.response.json();",
                "pm.test('is_guest = true', () => pm.expect(body.is_guest).to.eql(true));",
                "pm.test('csrf set', () => pm.expect(body.csrf).to.be.a('string').and.not.empty);"
              ] }
            }
          ]
        },
        {
          "name": "2. Register (POST /auth/register)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "const body = pm.response.json();",
                "pm.test('is_guest = false', () => pm.expect(body.is_guest).to.eql(false));",
                "pm.test('role = customer', () => pm.expect(body.role).to.eql('customer'));"
              ] }
            }
          ]
        },
        {
          "name": "3. Verify session (GET /auth/session)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/session", "host": ["{{baseUrl}}"], "path": ["auth", "session"] }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "const body = pm.response.json();",
                "pm.test('role = customer', () => pm.expect(body.role).to.eql('customer'));"
              ] }
            }
          ]
        },
        {
          "name": "4. Get profile (GET /profile)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/profile", "host": ["{{baseUrl}}"], "path": ["profile"] }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));"
              ] }
            }
          ]
        },
        {
          "name": "5. Patch profile (PATCH /profile)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/profile", "host": ["{{baseUrl}}"], "path": ["profile"] },
            "body": { "mode": "raw", "raw": "{\n  \"first_name\": \"Иван\",\n  \"last_name\": \"Петров\",\n  \"phone\": \"+79001234567\",\n  \"allergens\": [\"shellfish\"],\n  \"dietary\": [\"vegan\"]\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));"
              ] }
            }
          ]
        },
        {
          "name": "6. Change password (PATCH /auth/password)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/password", "host": ["{{baseUrl}}"], "path": ["auth", "password"] },
            "body": { "mode": "raw", "raw": "{\n  \"current_password\": \"{{password}}\",\n  \"new_password\": \"{{newPassword}}\"\n}" }
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('204 No Content', () => pm.response.to.have.status(204));"
            ] } }
          ]
        },
        {
          "name": "7. Logout (POST /auth/logout)",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('204 No Content', () => pm.response.to.have.status(204));",
              "pm.collectionVariables.set('csrf', '');"
            ] } }
          ]
        },
        {
          "name": "8. Guest after logout (GET /auth/session)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/session", "host": ["{{baseUrl}}"], "path": ["auth", "session"] }
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "pm.test('is_guest = true', () => pm.expect(pm.response.json().is_guest).to.eql(true));"
            ] } }
          ]
        },
        {
          "name": "9. Login with new password (POST /auth/login)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{newPassword}}\"\n}" }
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "pm.test('role = customer', () => pm.expect(pm.response.json().role).to.eql('customer'));"
            ] } }
          ]
        },
        {
          "name": "10. Login wrong password (POST /auth/login → 401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"wrong\"\n}" }
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('401 Unauthorized', () => pm.response.to.have.status(401));",
              "pm.test('code = invalid_credentials', () => pm.expect(pm.response.json().error.code).to.eql('invalid_credentials'));"
            ] } }
          ]
        },
        {
          "name": "11. Duplicate email (POST /auth/register → 409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"anotherpass\"\n}" }
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('409 Conflict', () => pm.response.to.have.status(409));",
              "pm.test('code = email_already_taken', () => pm.expect(pm.response.json().error.code).to.eql('email_already_taken'));"
            ] } }
          ]
        },
        {
          "name": "12. Profile w/o auth (Logout then GET /profile → 401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/profile", "host": ["{{baseUrl}}"], "path": ["profile"] }
          },
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "const baseUrl = pm.collectionVariables.get('baseUrl');",
              "const csrf = pm.collectionVariables.get('csrf');",
              "pm.sendRequest({",
              "    url: baseUrl + '/auth/logout',",
              "    method: 'POST',",
              "    header: { 'X-CSRF-Token': csrf || '' }",
              "}, () => { pm.collectionVariables.set('csrf', ''); });"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('401 Unauthorized', () => pm.response.to.have.status(401));"
            ] } }
          ]
        },
        {
          "name": "13. CSRF missing (POST /auth/register без X-CSRF-Token → 403)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"another@example.com\",\n  \"password\": \"secret123\"\n}" }
          },
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "const baseUrl = pm.collectionVariables.get('baseUrl');",
              "pm.sendRequest({ url: baseUrl + '/auth/session', method: 'GET' }, () => {",
              "    pm.collectionVariables.set('csrf', '');",
              "});"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('403 Forbidden', () => pm.response.to.have.status(403));"
            ] } }
          ]
        }
      ]
    },
    {
      "name": "Menu — public",
      "description": "Доступно гостям (без логина). Пройди эти запросы как guest или customer.",
      "item": [
        {
          "name": "List categories (GET /categories)",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] } },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "pm.test('items array', () => pm.expect(pm.response.json().items).to.be.an('array'));"
          ] } }]
        },
        {
          "name": "List dishes (GET /menu)",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/menu?limit=20&offset=0", "host": ["{{baseUrl}}"], "path": ["menu"], "query": [
            { "key": "limit",  "value": "20" },
            { "key": "offset", "value": "0" }
          ] } },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('shape', () => { pm.expect(body).to.have.all.keys('items', 'total', 'limit', 'offset'); });"
          ] } }]
        },
        {
          "name": "List dishes — filtered (GET /menu?category_id&exclude_allergens&dietary&q&tag_ids)",
          "request": { "method": "GET", "header": [], "url": {
            "raw": "{{baseUrl}}/menu?category_id={{categoryId}}&exclude_allergens=gluten&exclude_allergens=dairy&dietary=vegan&q=&tag_ids={{tagId}}&limit=20&offset=0",
            "host": ["{{baseUrl}}"], "path": ["menu"], "query": [
              { "key": "category_id",       "value": "{{categoryId}}" },
              { "key": "exclude_allergens", "value": "gluten" },
              { "key": "exclude_allergens", "value": "dairy" },
              { "key": "dietary",           "value": "vegan" },
              { "key": "q",                 "value": "" },
              { "key": "tag_ids",           "value": "{{tagId}}" },
              { "key": "limit",             "value": "20" },
              { "key": "offset",            "value": "0" }
            ] } },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));"
          ] } }]
        },
        {
          "name": "Get dish (GET /menu/{id})",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/menu/{{dishId}}", "host": ["{{baseUrl}}"], "path": ["menu", "{{dishId}}"] } },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "const d = pm.response.json();",
            "pm.test('id matches', () => pm.expect(String(d.id)).to.eql(pm.collectionVariables.get('dishId')));"
          ] } }]
        },
        {
          "name": "Get dish — not found (GET /menu/999999 → 404)",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/menu/999999", "host": ["{{baseUrl}}"], "path": ["menu", "999999"] } },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('404', () => pm.response.to.have.status(404));",
            "pm.test('code = dish_not_found', () => pm.expect(pm.response.json().error.code).to.eql('dish_not_found'));"
          ] } }]
        }
      ]
    },
    {
      "name": "Chats",
      "description": "Чат с ассистентом. Требует customer-сессии (зарегистрироваться через секцию Auth перед запуском). На A1 ответ ассистента — echo-заглушка через SSE (event: meta → token → done).",
      "item": [
        {
          "name": "1. Active chat (GET /chats/active)",
          "description": "Возвращает текущий чат пользователя или создаёт новый, если последний устарел (по умолчанию TTL 6 часов). Сохраняет chatId в коллекционную переменную.",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/chats/active", "host": ["{{baseUrl}}"], "path": ["chats", "active"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('id is uuid', () => pm.expect(body.id).to.match(/^[0-9a-f-]{36}$/i));",
            "pm.test('user_id present', () => pm.expect(body.user_id).to.be.a('string'));",
            "pm.collectionVariables.set('chatId', body.id);"
          ] } }]
        },
        {
          "name": "2. List chats (GET /chats)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/chats?limit=20&offset=0",
              "host": ["{{baseUrl}}"], "path": ["chats"],
              "query": [
                { "key": "limit",  "value": "20" },
                { "key": "offset", "value": "0" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('shape', () => pm.expect(body).to.have.all.keys('items','total','limit','offset'));"
          ] } }]
        },
        {
          "name": "3. Create new chat (POST /chats)",
          "description": "Принудительно создаёт новый чат, не зависит от auto-new-after.",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/chats", "host": ["{{baseUrl}}"], "path": ["chats"] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Обед в офисе\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201 Created', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.test('title set', () => pm.expect(body.title).to.eql('Обед в офисе'));",
            "pm.collectionVariables.set('chatId', body.id);"
          ] } }]
        },
        {
          "name": "4. Send message (POST /chats/{id}/messages, SSE)",
          "description": "Отвечает SSE-стримом: event: meta → event: token → event: done. На A1 ассистент эхо-отвечает; реальный LLM появится в шаге A3.",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/chats/{{chatId}}/messages", "host": ["{{baseUrl}}"], "path": ["chats", "{{chatId}}", "messages"] },
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Что у вас острого без молочки?\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "pm.test('content-type SSE', () => pm.expect(pm.response.headers.get('Content-Type') || '').to.include('text/event-stream'));",
            "const text = pm.response.text();",
            "pm.test('contains meta event',  () => pm.expect(text).to.include('event: meta'));",
            "pm.test('contains token event', () => pm.expect(text).to.include('event: token'));",
            "pm.test('contains done event',  () => pm.expect(text).to.include('event: done'));",
            "pm.test('echo includes prompt', () => pm.expect(text).to.include('echo: Что у вас острого без молочки?'));"
          ] } }]
        },
        {
          "name": "5. Get chat with messages (GET /chats/{id})",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/chats/{{chatId}}?messages_limit=50",
              "host": ["{{baseUrl}}"], "path": ["chats", "{{chatId}}"],
              "query": [
                { "key": "messages_limit", "value": "50" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('chat present', () => pm.expect(body.chat).to.be.an('object'));",
            "pm.test('messages array', () => pm.expect(body.messages).to.be.an('array'));",
            "pm.test('first message role = user', () => pm.expect(body.messages[0].role).to.eql('user'));",
            "pm.test('second message role = assistant', () => pm.expect(body.messages[1].role).to.eql('assistant'));",
            "pm.test('ASC order — created_at growing', () => {",
            "  for (let i = 1; i < body.messages.length; i++) {",
            "    pm.expect(new Date(body.messages[i].created_at).getTime()).to.be.at.least(new Date(body.messages[i-1].created_at).getTime());",
            "  }",
            "});"
          ] } }]
        },
        {
          "name": "6. Send empty message (→ 400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/chats/{{chatId}}/messages", "host": ["{{baseUrl}}"], "path": ["chats", "{{chatId}}", "messages"] },
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('400 Bad Request', () => pm.response.to.have.status(400));"
          ] } }]
        },
        {
          "name": "7. Foreign chat (→ 403/404)",
          "description": "Несуществующий или чужой chat_id — должен дать 404 (не найден) или 403 (не наш).",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/chats/00000000-0000-0000-0000-000000000000", "host": ["{{baseUrl}}"], "path": ["chats", "00000000-0000-0000-0000-000000000000"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('404 or 403', () => pm.expect([403, 404]).to.include(pm.response.code));"
          ] } }]
        },
        {
          "name": "8. Delete chat (DELETE /chats/{id})",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/chats/{{chatId}}", "host": ["{{baseUrl}}"], "path": ["chats", "{{chatId}}"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('204 No Content', () => pm.response.to.have.status(204));",
            "pm.collectionVariables.set('chatId', '');"
          ] } }]
        }
      ]
    },
    {
      "name": "Admin — login",
      "description": "Логин под admin'ом. Перед запуском убедись, что в БД есть admin: см. POSTMAN.md, секция «Подготовить admin».",
      "item": [
        {
          "name": "Bootstrap session (GET /auth/session)",
